@page "{id:int}"
@model GolfClub.Pages.Bookings.EditModel
@{
    ViewData["Title"] = "Edit Booking";
}

<h2>Edit Booking</h2>
<p><strong>Date:</strong> @Model.Booking.Date.ToString("dddd, dd MMMM yyyy")</p>
<p><strong>Time:</strong> @Model.Booking.TimeSlot.ToString("HH:mm")</p>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<h5>Players (@Model.Booking.Players.Count / 4)</h5>
<table class="table table-sm w-auto">
    @foreach (var player in Model.Booking.Players)
    {
        <tr>
            <td class="pe-3">@player.Member.Name</td>
            <td class="pe-3">Handicap: @player.HandicapAtBooking</td>
            <td>
                <form method="post" asp-page-handler="Remove" asp-route-id="@Model.Booking.BookingId" asp-route-playerId="@player.BookingPlayerId" style="display:inline">
                    <button class="btn btn-sm btn-outline-danger">Remove</button>
                </form>
            </td>
        </tr>
    }
</table>

@if (Model.Booking.Players.Count < 4)
{
    <h5 class="mt-3">Add Player</h5>
    <form method="post" asp-page-handler="Add" asp-route-id="@Model.Booking.BookingId" class="d-flex gap-2 align-items-end">
        <div>
            <label asp-for="SelectedMemberId" class="form-label">Member</label>
            <select asp-for="SelectedMemberId" asp-items="Model.AvailableMembers" class="form-select">
                <option value="">— select member —</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">Add</button>
    </form>
}

<div class="mt-3">
    <a asp-page="TeeSheet" asp-route-date="@Model.Booking.Date.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary">Back to Tee Sheet</a>
</div>
