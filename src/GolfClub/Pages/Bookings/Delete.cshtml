@page "{id:int}"
@model GolfClub.Pages.Bookings.DeleteModel
@{
    ViewData["Title"] = "Cancel Booking";
}

<h2>Cancel Booking</h2>
<div class="alert alert-warning">Are you sure you want to cancel this booking?</div>

<p><strong>Date:</strong> @Model.Booking.Date.ToString("dddd, dd MMMM yyyy")</p>
<p><strong>Time:</strong> @Model.Booking.TimeSlot.ToString("HH:mm")</p>

<h5>Players</h5>
<ul>
    @foreach (var player in Model.Booking.Players)
    {
        <li>@player.Member.Name (Handicap: @player.HandicapAtBooking)</li>
    }
</ul>

<form method="post">
    <button type="submit" class="btn btn-danger">Yes, Cancel Booking</button>
    <a asp-page="TeeSheet" asp-route-date="@Model.Booking.Date.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary">No, Go Back</a>
</form>
