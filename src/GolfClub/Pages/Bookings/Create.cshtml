@page
@model GolfClub.Pages.Bookings.CreateModel
@{
    ViewData["Title"] = "Book Tee Time";
}

<h2>Book Tee Time</h2>
<p><strong>Date:</strong> @Model.Date.ToString("dddd, dd MMMM yyyy")</p>
<p><strong>Time:</strong> @Model.TimeSlot.ToString("HH:mm")</p>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post">
    <input type="hidden" asp-for="Date" />
    <input type="hidden" asp-for="TimeSlot" />

    <div class="mb-3">
        <label class="form-label">Player 1 (required)</label>
        <select asp-for="SelectedMemberId" asp-items="Model.Members" class="form-select">
            <option value="">— select member —</option>
        </select>
    </div>

    @for (int i = 0; i < 3; i++)
    {
        <div class="mb-3">
            <label class="form-label">Player @(i + 2) (optional)</label>
            <select name="AdditionalMemberIds" class="form-select">
                <option value="0">— none —</option>
                @foreach (var item in Model.Members)
                {
                    <option value="@item.Value">@item.Text</option>
                }
            </select>
        </div>
    }

    <button type="submit" class="btn btn-primary">Book</button>
    <a asp-page="TeeSheet" asp-route-date="@Model.Date.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary">Cancel</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
