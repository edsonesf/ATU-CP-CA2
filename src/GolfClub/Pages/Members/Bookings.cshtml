@page "{id:int}"
@model GolfClub.Pages.Members.BookingsModel
@{
    ViewData["Title"] = "Bookings";
}

<h2>Bookings — @Model.Member.Name</h2>
<p><strong>Membership:</strong> @Model.Member.MembershipNumber &nbsp;|&nbsp; <strong>Handicap:</strong> @Model.Member.Handicap</p>
<a asp-page="Index" class="btn btn-outline-secondary mb-3">Back to Members</a>

@if (!Model.Bookings.Any())
{
    <p class="text-muted">No bookings found for this member.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Players</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model.Bookings)
            {
                <tr>
                    <td>@booking.Date.ToString("ddd, dd MMM yyyy")</td>
                    <td>@booking.TimeSlot.ToString("HH:mm")</td>
                    <td>@string.Join(", ", booking.Players.Select(p => p.Member.Name))</td>
                    <td>
                        <a asp-page="/Bookings/TeeSheet" asp-route-date="@booking.Date.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline-primary">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
